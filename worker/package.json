{
  "name": "infobuilder-worker",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "migrate:local": "wrangler d1 migrations apply infobuilder-db --local",
    "migrate:remote": "wrangler d1 migrations apply infobuilder-db --remote",
    "seed:local": "wrangler d1 execute infobuilder-db --file=seed.sql --local",
    "seed:remote": "wrangler d1 execute infobuilder-db --file=seed.sql --remote",
    "seed_music:local": "wrangler d1 execute infobuilder-db --file=seed_music.sql --local",
    "seed_music:remote": "wrangler d1 execute infobuilder-db --file=seed_music.sql --remote"
  },
  "dependencies": {
    "hono": "^4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250515.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.14.0"
  }
}
